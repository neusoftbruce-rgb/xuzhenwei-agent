/* 全局样式 */
page {
  --bg: #0f0f1a;
  --surface: #18182a;
  --border: #2a2a48;
  --text: #cdcde6;
  --text2: #7c7ca0;
  --accent: #7c5cfc;
  --accent2: #5b8def;
  --accent3: #4ecb71;
  --warn: #f0a050;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  height: 100vh;
}

.page { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

/* 导航栏 */
.navbar {
  height: 88rpx; display: flex; align-items: center; padding: 0 24rpx;
  background: var(--surface); border-bottom: 1rpx solid var(--border);
  gap: 16rpx; flex-shrink: 0;
}
.navbar .title { font-size: 32rpx; font-weight: 600; flex: 1; color: var(--text); }
.navbar .nav-btn {
  width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex;
  align-items: center; justify-content: center; font-size: 36rpx;
  background: transparent; border: none; color: var(--text2);
}

/* 模式快选条 */
.mode-bar {
  flex-shrink: 0; padding: 12rpx 16rpx; display: flex; gap: 10rpx;
  white-space: nowrap; background: var(--bg);
  border-bottom: 1rpx solid rgba(42,42,72,0.5);
}
.mode-chip {
  flex-shrink: 0; padding: 10rpx 24rpx; border-radius: 32rpx;
  font-size: 24rpx; border: 1rpx solid var(--border);
  background: transparent; color: var(--text2);
}
.mode-chip.on { background: var(--accent); border-color: var(--accent); color: #fff; }

/* 聊天区 */
.chat { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; }
.welcome { text-align: center; padding: 100rpx 40rpx 60rpx; }
.welcome .icon { font-size: 100rpx; margin-bottom: 24rpx; }
.welcome .title {
  font-size: 36rpx; margin-bottom: 16rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent2), var(--accent3));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.welcome .desc { color: var(--text2); font-size: 26rpx; line-height: 1.8; }

/* 消息气泡 */
.msg { margin-bottom: 20rpx; max-width: 85%; animation: fadeIn 0.2s; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8rpx); } to { opacity: 1; transform: translateY(0); } }
.msg-user { align-self: flex-end; }
.msg-ai, .msg-sys { align-self: flex-start; }
.msg-recommend { align-self: flex-start; max-width: 92%; }

.bubble {
  padding: 18rpx 24rpx; border-radius: 24rpx; font-size: 28rpx;
  line-height: 1.65; word-break: break-word;
}
.bubble-user {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff; border-bottom-right-radius: 8rpx;
}
.bubble-ai {
  background: var(--surface); border: 1rpx solid var(--border);
  border-bottom-left-radius: 8rpx;
}
.bubble-sys {
  background: transparent; color: var(--text2); font-size: 22rpx;
  text-align: center; padding: 8rpx;
}

/* 推荐卡片 */
.rec-keywords { display: flex; gap: 8rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.rec-keywords text { font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 16rpx; background: rgba(124,92,252,0.15); color: var(--accent2); }
.rec-cards { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 12rpx; }
.rec-card {
  display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx;
  border-radius: 16rpx; background: rgba(30,30,56,0.6); border: 1rpx solid var(--border);
}
.rec-card .rc-id { font-size: 20rpx; background: var(--accent); color: #fff; padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.rec-card .rc-info { flex: 1; }
.rec-card .rc-name { font-size: 24rpx; font-weight: 600; }
.rec-card .rc-reason { font-size: 20rpx; color: var(--text2); margin-top: 2rpx; }
.rec-card .rc-pct { font-size: 24rpx; font-weight: 700; color: var(--accent2); }
.rec-actions { display: flex; gap: 12rpx; }
.rec-actions button { flex: 1; padding: 18rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; border: none; }
.btn-go { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #fff; }
.btn-swap { background: transparent; border: 1rpx solid var(--border)!important; color: var(--text2); }

/* 底部输入栏 */
.bottom-bar {
  flex-shrink: 0; padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--surface); border-top: 1rpx solid var(--border);
  display: flex; gap: 12rpx; align-items: flex-end;
}
.bottom-bar textarea {
  flex: 1; padding: 16rpx 24rpx; border-radius: 40rpx;
  border: 1rpx solid var(--border); background: #1e1e38;
  color: var(--text); font-size: 30rpx; min-height: 72rpx; max-height: 200rpx;
}
.bottom-bar .btn-send {
  width: 72rpx; height: 72rpx; border-radius: 50%; border: none;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff; font-size: 32rpx; display: flex; align-items: center; justify-content: center;
}
.bottom-bar .btn-send[disabled] { opacity: 0.4; }

/* 语音按钮 */
.btn-voice {
  width: 72rpx; height: 72rpx; border-radius: 50%; border: 1rpx solid var(--border);
  background: transparent; font-size: 36rpx; display: flex;
  align-items: center; justify-content: center; padding: 0;
}
.btn-voice.recording {
  background: rgba(240,80,80,0.12); border-color: #f05050; color: #f05050;
  animation: micPulse 1.5s infinite;
}
@keyframes micPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(240,80,80,0.3); }
  50% { box-shadow: 0 0 0 16rpx rgba(240,80,80,0); }
}

/* 抽屉 */
.drawer-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; display: none; }
.drawer-mask.show { display: block; }
.drawer {
  position: fixed; top: 0; left: 0; bottom: 0; width: 560rpx; max-width: 85vw;
  background: var(--surface); z-index: 60; transform: translateX(-100%);
  transition: transform 0.25s; display: flex; flex-direction: column;
}
.drawer.open { transform: translateX(0); }
.drawer-hd {
  padding: 32rpx; border-bottom: 1rpx solid var(--border);
  display: flex; align-items: center; gap: 16rpx;
}
.drawer-hd text { font-size: 30rpx; font-weight: 600; flex: 1; }
.drawer-hd .btn-new {
  padding: 12rpx 24rpx; border-radius: 32rpx;
  border: 1rpx dashed var(--accent3); background: transparent;
  color: var(--accent3); font-size: 24rpx;
}
.drawer-list { flex: 1; overflow-y: auto; padding: 12rpx; }
.session-item {
  padding: 20rpx 24rpx; border-radius: 16rpx; display: flex;
  justify-content: space-between; align-items: center; margin: 4rpx 0;
}
.session-item.active { background: rgba(124,92,252,0.12); }
.si-name { font-size: 28rpx; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.si-time { font-size: 22rpx; color: var(--text2); margin-left: 16rpx; flex-shrink: 0; }
.empty { text-align: center; color: var(--text2); font-size: 24rpx; padding: 60rpx; }

/* 技法列表 */
.tech-list { padding: 20rpx; }
.tech-tabs { display: flex; gap: 10rpx; margin-bottom: 20rpx; flex-wrap: wrap; }
.tech-tab {
  padding: 12rpx 24rpx; border-radius: 32rpx; font-size: 24rpx;
  border: 1rpx solid var(--border); background: transparent; color: var(--text2);
}
.tech-tab.on { background: var(--accent); border-color: var(--accent); color: #fff; }
.tech-item {
  padding: 24rpx; margin: 8rpx 0; border-radius: 16rpx;
  background: var(--surface); border: 1rpx solid var(--border);
}
.tech-item .t-id { font-size: 20rpx; background: var(--accent); color: #fff; padding: 2rpx 10rpx; border-radius: 6rpx; display: inline-block; margin-bottom: 8rpx; }
.tech-item .t-name { font-size: 28rpx; font-weight: 600; }
.tech-item .t-desc { font-size: 22rpx; color: var(--text2); margin-top: 6rpx; }

/* 个人中心 */
.profile { padding: 40rpx; }
.profile .avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--accent); margin: 0 auto 20rpx; display: flex; align-items: center; justify-content: center; font-size: 56rpx; }
.profile .nickname { text-align: center; font-size: 32rpx; font-weight: 600; margin-bottom: 40rpx; }
.profile .btn {
  width: 100%; padding: 24rpx; border-radius: 16rpx; margin: 12rpx 0;
  text-align: center; font-size: 28rpx; background: var(--surface); border: 1rpx solid var(--border); color: var(--text);
}
.profile .btn.warn { color: #f05050; border-color: rgba(240,80,80,0.3); }

/* 导出按钮 */
.export-btn { display: flex; justify-content: flex-end; margin-top: 12rpx; }
.export-btn button { padding: 10rpx 24rpx; border-radius: 12rpx; font-size: 22rpx; border: 1rpx solid var(--border); background: transparent; color: var(--text2); }

/* 打字动画 */
.typing { display: flex; gap: 6rpx; padding: 10rpx 0; }
.typing view { width: 10rpx; height: 10rpx; background: var(--warn); border-radius: 50%; animation: bounce 1.4s infinite; }
.typing view:nth-child(2) { animation-delay: 0.2s; }
.typing view:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { opacity: 0.2; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-10rpx); }
}

/* Toast */
.toast {
  position: fixed; top: 120rpx; left: 50%; transform: translateX(-50%);
  background: var(--accent3); color: #000; padding: 12rpx 36rpx;
  border-radius: 40rpx; font-size: 26rpx; font-weight: 600; z-index: 100;
}
