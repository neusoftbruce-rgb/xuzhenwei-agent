<!-- 个人中心 -->
<view class="page">
  <view class="navbar">
    <text class="title">我的</text>
  </view>

  <view class="profile">
    <!-- 未登录 -->
    <view wx:if="{{!loggedIn}}">
      <view class="avatar">👤</view>
      <view class="nickname">未登录</view>
      <button class="btn" style="background:var(--accent);color:#fff" bindtap="handleLogin">微信一键登录</button>
      <button class="btn" bindtap="testLogin">🔧 开发测试登录</button>
    </view>

    <!-- 已登录 -->
    <view wx:else>
      <image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}"></image>
      <view wx:else class="avatar">🌱</view>
      <view class="nickname">{{user.nickname||'用户'}}</view>
      <button class="btn" bindtap="handleLogout">退出登录</button>
    </view>

    <view style="margin-top:60rpx">
      <button class="btn">📖 使用帮助</button>
      <button class="btn">📧 意见反馈</button>
      <button class="btn warn" bindtap="clearData">🗑 清除缓存</button>
    </view>

    <view style="text-align:center;margin-top:60rpx;font-size:22rpx;color:var(--text2)">
      徐振伟智能体 v1.0<br/>Powered by DeepSeek + Spring Boot
    </view>
  </view>
</view>
